# Copy this file to keystore.properties (same directory) and fill in the values.
# keystore.properties is git-ignored and must NEVER be committed.
#
# HOW TO CREATE A KEYSTORE (run once, keep the .jks file safe):
#   keytool -genkey -v -keystore kixxme-release-key.jks \
#           -alias kixxme -keyalg RSA -keysize 2048 -validity 10000
#
# Place the .jks file anywhere outside the repo, then set storeFile to its path.
# Relative paths are resolved from artifacts/kixxme/android/app/.

storeFile=../../kixxme-release-key.jks
storePassword=CHANGE_ME
keyAlias=kixxme
keyPassword=CHANGE_ME
