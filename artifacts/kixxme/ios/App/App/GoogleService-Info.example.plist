<?xml version="1.0" encoding="UTF-8"?>
<!--
  PLACEHOLDER ONLY. Download the real GoogleService-Info.plist from Firebase
  Console (Project settings -> Your apps -> iOS app, bundle id com.kixxme.app)
  and save it as ios/App/App/GoogleService-Info.plist (drop the .example), then
  drag it into the Xcode "App" target so it is bundled. AppDelegate calls
  FirebaseApp.configure() only when this file is present, so builds without it
  still launch (push disabled). Do NOT rename or commit secrets in this example.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>REPLACE_WITH_REAL_IOS_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>000000000000</string>
	<key>BUNDLE_ID</key>
	<string>com.kixxme.app</string>
	<key>PROJECT_ID</key>
	<string>kixxme-REPLACE_ME</string>
	<key>STORAGE_BUCKET</key>
	<string>kixxme-REPLACE_ME.appspot.com</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>GOOGLE_APP_ID</key>
	<string>1:000000000000:ios:0000000000000000000000</string>
</dict>
</plist>
